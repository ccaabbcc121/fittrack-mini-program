/* app.wxss - 全局样式 */
page {
  --primary: #0f3460;
  --primary-light: #16213e;
  --secondary: #e94560;
  --accent: #533483;
  --bg: #f5f5f5;
  --bg-card: #ffffff;
  --text: #1a1a2e;
  --text-secondary: #8e8e93;
  --text-light: #b0b0b0;
  --border: #e8e8e8;
  --success: #34c759;
  --warning: #ff9500;
  --danger: #ff3b30;
  --shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  --radius: 12px;
  --radius-sm: 8px;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  color: var(--text);
  background-color: var(--bg);
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 16px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #ffffff;
  border: none;
  border-radius: var(--radius-sm);
  padding: 12px 24px;
  font-size: 16px;
  font-weight: 500;
  text-align: center;
}

.btn-primary[disabled] {
  background: #c8c8cc;
  color: #ffffff;
  opacity: 0.6;
}

.btn-secondary {
  background: #ffffff;
  color: var(--primary);
  border: 1px solid var(--primary);
  border-radius: var(--radius-sm);
  padding: 12px 24px;
  font-size: 16px;
  text-align: center;
}

.btn-danger {
  background: var(--danger);
  color: #ffffff;
  border: none;
  border-radius: var(--radius-sm);
  padding: 12px 24px;
  font-size: 16px;
  text-align: center;
}

.btn-small {
  padding: 6px 16px;
  font-size: 13px;
  border-radius: 20px;
}

/* 表单 */
.form-group {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 6px;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 12px;
  font-size: 14px;
  background: #fff;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--primary);
}

.form-textarea {
  width: 100%;
  min-height: 80px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 10px 12px;
  font-size: 14px;
  background: #fff;
  box-sizing: border-box;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 500;
}

.tag-primary { background: rgba(15, 52, 96, 0.1); color: var(--primary); }
.tag-success { background: rgba(52, 199, 89, 0.1); color: var(--success); }
.tag-warning { background: rgba(255, 149, 0, 0.1); color: var(--warning); }
.tag-danger  { background: rgba(255, 59, 48, 0.1); color: var(--danger); }

/* 分割线 */
.divider {
  height: 1px;
  background: var(--border);
  margin: 12px 0;
}

/* 文本 */
.text-center { text-align: center; }
.text-right  { text-align: right; }
.text-muted  { color: var(--text-secondary); font-size: 13px; }
.text-small  { font-size: 12px; }

/* Flex 布局 */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* 间距 */
.mt-8  { margin-top: 8px; }
.mt-12 { margin-top: 12px; }
.mt-16 { margin-top: 16px; }
.mb-8  { margin-bottom: 8px; }
.mb-12 { margin-bottom: 12px; }
.mb-16 { margin-bottom: 16px; }
.ml-8  { margin-left: 8px; }
.mr-8  { margin-right: 8px; }
.p-12 { padding: 12px; }
.p-16 { padding: 16px; }

/* 徽标 */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 18px;
  height: 18px;
  border-radius: 9px;
  background: var(--danger);
  color: #fff;
  font-size: 11px;
  padding: 0 5px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-state image {
  width: 160px;
  height: 160px;
  margin-bottom: 16px;
}

.empty-state .text {
  color: var(--text-secondary);
  font-size: 14px;
}
