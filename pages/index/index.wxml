<!-- pages/index/index.wxml -->
<view class="page">
  <view class="header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="greeting">
        <text class="greeting-text">{{greeting}}</text>
        <text class="user-name">{{userInfo.nickname || '用户'}}</text>
      </view>
      <view class="header-stats">
        <view class="stat-item" bindtap="goToWeight">
          <text class="stat-value">{{userInfo.weight || '--'}}</text>
          <text class="stat-label">体重(kg)</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="goToBMI">
          <text class="stat-value">{{bmi}}</text>
          <text class="stat-label">BMI</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{stats.weeklyWorkouts || 0}}</text>
          <text class="stat-label">本周训练</text>
        </view>
      </view>
    </view>
  </view>

  <view class="quick-actions">
    <view class="action-card" bindtap="goToTraining">
      <view class="action-icon">🏋️</view>
      <text class="action-text">开始训练</text>
    </view>
    <view class="action-card" bindtap="goToDiet">
      <view class="action-icon">🥗</view>
      <text class="action-text">记录饮食</text>
    </view>
    <view class="action-card" bindtap="goToWeight">
      <view class="action-icon">⚖️</view>
      <text class="action-text">体重管理</text>
    </view>
    <view class="action-card" bindtap="goToBMI">
      <view class="action-icon">📊</view>
      <text class="action-text">BMI计算</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">今日概览</text>
      <text class="section-date">{{today}}</text>
    </view>
    <view class="overview-cards">
      <view class="overview-card">
        <text class="overview-value">{{todayWorkouts}}次</text>
        <text class="overview-label">训练打卡</text>
      </view>
      <view class="overview-card">
        <text class="overview-value">{{todayCalories}}kcal</text>
        <text class="overview-label">消耗热量</text>
      </view>
      <view class="overview-card">
        <text class="overview-value">{{todayIntake}}kcal</text>
        <text class="overview-label">摄入热量</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">最近训练</text>
      <text class="section-more" bindtap="goToHistory">查看全部 ›</text>
    </view>
    <view wx:if="{{recentWorkouts.length === 0}}" class="empty-card">
      <text class="empty-text">暂无训练记录</text>
      <text class="empty-sub">快去开始你的第一次训练吧</text>
    </view>
    <view wx:for="{{recentWorkouts}}" wx:key="id" class="card workout-card">
      <view class="card-left">
        <view class="workout-icon-wrap">
          <text class="workout-icon">💪</text>
        </view>
        <view class="workout-info">
          <text class="workout-name">{{item.planName}}</text>
          <text class="workout-date">{{item.recordDate}} · {{item.duration}}分钟</text>
        </view>
      </view>
      <view class="card-right">
        <text class="calories-text">{{item.calories}}</text>
        <text class="calories-unit">kcal</text>
      </view>
    </view>
  </view>
</view>
