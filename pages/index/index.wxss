/* pages/index/index.wxss */
.page { padding-bottom: 30px; }
.header { position: relative; padding: 0 16px 24px; color: #fff; }
.header-bg { position: absolute; top: 0; left: 0; right: 0; height: 260px; background: linear-gradient(160deg, #0f3460, #16213e); border-radius: 0 0 30px 30px; }
.header-content { position: relative; z-index: 1; padding-top: 12px; }
.greeting-text { font-size: 15px; opacity: 0.8; }
.user-name { display: block; font-size: 24px; font-weight: 700; margin-top: 4px; }
.header-stats { display: flex; align-items: center; margin-top: 20px; background: rgba(255,255,255,0.1); border-radius: 12px; padding: 14px 0; }
.stat-item { flex: 1; text-align: center; }
.stat-value { display: block; font-size: 20px; font-weight: 700; }
.stat-label { font-size: 12px; opacity: 0.7; margin-top: 2px; }
.stat-divider { width: 1px; height: 28px; background: rgba(255,255,255,0.2); }
.quick-actions { display: flex; padding: 16px; gap: 10px; margin-top: -12px; position: relative; z-index: 2; }
.action-card { flex: 1; background: #fff; border-radius: 12px; padding: 16px 8px; text-align: center; box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
.action-icon { font-size: 28px; margin-bottom: 6px; }
.action-text { font-size: 12px; color: #666; font-weight: 500; }
.section { padding: 0 16px; margin-top: 8px; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.section-title { font-size: 17px; font-weight: 600; }
.section-date { font-size: 13px; color: #999; }
.section-more { font-size: 13px; color: #0f3460; }
.overview-cards { display: flex; gap: 10px; }
.overview-card { flex: 1; background: #fff; border-radius: 12px; padding: 16px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
.overview-value { display: block; font-size: 24px; font-weight: 700; color: #0f3460; }
.overview-label { font-size: 12px; color: #999; margin-top: 4px; }
.workout-card { display: flex; justify-content: space-between; align-items: center; }
.card-left { display: flex; align-items: center; gap: 12px; }
.workout-icon-wrap { width: 44px; height: 44px; border-radius: 12px; background: rgba(15,52,96,0.08); display: flex; align-items: center; justify-content: center; }
.workout-icon { font-size: 22px; }
.workout-info { display: flex; flex-direction: column; }
.workout-name { font-size: 15px; font-weight: 500; }
.workout-date { font-size: 12px; color: #999; margin-top: 2px; }
.calories-text { font-size: 20px; font-weight: 700; color: #e94560; }
.calories-unit { font-size: 11px; color: #999; display: block; text-align: right; }
.empty-card { background: #fff; border-radius: 12px; padding: 40px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
.empty-text { font-size: 15px; color: #999; }
.empty-sub { font-size: 12px; color: #ccc; margin-top: 4px; display: block; }
