/* pages/login/login.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0f3460 0%, #16213e 50%, #1a1a2e 100%);
}
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40px 32px;
}
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60px;
}
.logo-icon { font-size: 72px; margin-bottom: 16px; }
.app-name { font-size: 36px; font-weight: 700; color: #ffffff; letter-spacing: 2px; }
.app-slogan { font-size: 14px; color: rgba(255,255,255,0.6); margin-top: 8px; }
.form-section { width: 100%; }
.login-btn {
  width: 100%;
  height: 52px;
  border-radius: 26px;
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}
.wechat-btn { background: #07c160; color: #fff; }
.mock-btn { background: rgba(255,255,255,0.15); color: #fff; border: 1px solid rgba(255,255,255,0.3); }
.wechat-icon { font-size: 20px; margin-right: 8px; }
.divider-text {
  display: flex;
  align-items: center;
  margin: 24px 0;
}
.divider-line { flex: 1; height: 1px; background: rgba(255,255,255,0.2); }
.divider-label { color: rgba(255,255,255,0.5); margin: 0 16px; font-size: 13px; }
.footer-text { margin-top: 40px; font-size: 12px; color: rgba(255,255,255,0.4); text-align: center; }
.footer-text .link { color: rgba(255,255,255,0.7); }
