<view class="page">
  <!-- ===== 概览卡片 ===== -->
  <view class="summary-card">
    <view class="summary-grid">
      <view class="summary-cell">
        <text class="s-val">{{latestWeight}}</text>
        <text class="s-lbl">最新体重(kg)</text>
      </view>
      <view class="summary-cell">
        <text class="s-val" style="color: {{changeColor}}">{{weightChange}}</text>
        <text class="s-lbl">变化(kg)</text>
      </view>
      <view class="summary-cell">
        <text class="s-val">{{bmi}}</text>
        <text class="s-lbl">BMI</text>
      </view>
      <view class="summary-cell" bindtap="goToChart">
        <text class="s-val">📈</text>
        <text class="s-lbl">趋势图 ›</text>
      </view>
    </view>
  </view>

  <!-- ===== 列表头部 ===== -->
  <view class="list-head">
    <text class="list-title">体重记录</text>
    <text class="list-count" wx:if="{{totalRecords > 0}}">{{totalRecords}} 条</text>
    <button class="btn-add" bindtap="showAddDialog">+ 添加</button>
  </view>

  <!-- ===== 空状态 ===== -->
  <view wx:if="{{records.length === 0}}" class="empty-state">
    <text class="empty-icon">⚖️</text>
    <text class="empty-text">暂无体重记录</text>
    <text class="empty-sub">定期记录体重，追踪身体变化趋势</text>
    <button class="btn-primary btn-sm mt-16" bindtap="showAddDialog">+ 添加第一条记录</button>
  </view>

  <!-- ===== 记录列表 ===== -->
  <view wx:else>
    <view wx:for="{{records}}" wx:key="id" class="record-card">
      <view class="rec-left">
        <text class="rec-date">{{item.recordDate}}</text>
        <text class="rec-bf" wx:if="{{item.bodyFat}}">体脂率 {{item.bodyFat}}%</text>
      </view>
      <view class="rec-right">
        <text class="rec-weight">{{item.weight}} kg</text>
        <text class="rec-edit" bindtap="handleEdit" data-id="{{item.id}}">编辑</text>
        <text class="rec-del" bindtap="handleDelete" data-id="{{item.id}}">删除</text>
      </view>
    </view>

    <view class="list-end">
      <text class="list-end-text">— 共 {{totalRecords}} 条记录 —</text>
    </view>
  </view>

  <!-- ===== 添加弹窗 ===== -->
  <view wx:if="{{showDialog}}" class="dialog-overlay" bindtap="closeDialog">
    <view class="dialog" catchtap="noop">
      <view class="dialog-head">
        <text class="dialog-title">{{isEdit ? '编辑体重记录' : '添加体重记录'}}</text>
        <text class="dialog-close" bindtap="closeDialog">✕</text>
      </view>

      <view class="dialog-body">
        <view class="form-item">
          <text class="form-label">体重（kg）*</text>
          <input
            class="form-input form-input-lg"
            type="digit"
            placeholder="70.0"
            value="{{form.weight}}"
            bindinput="onFormInput"
            data-field="weight"
            focus="{{true}}"
          />
        </view>

        <view class="form-item">
          <text class="form-label">体脂率（%）</text>
          <input
            class="form-input"
            type="digit"
            placeholder="18.0（选填）"
            value="{{form.bodyFat}}"
            bindinput="onFormInput"
            data-field="bodyFat"
          />
        </view>

        <view class="form-item">
          <text class="form-label">日期</text>
          <input
            class="form-input"
            type="text"
            placeholder="YYYY-MM-DD"
            value="{{form.recordDate}}"
            bindinput="onFormInput"
            data-field="recordDate"
          />
        </view>
      </view>

      <view class="dialog-footer">
        <button class="btn-cancel" bindtap="closeDialog">取消</button>
        <button
          class="btn-confirm"
          bindtap="handleAdd"
          disabled="{{!canSubmit}}"
          loading="{{submitting}}"
        >
          {{isEdit ? '保存' : '添加'}}
        </button>
      </view>
    </view>
  </view>
</view>
