/* pages/weight/list/list.wxss */
.page {
  padding: 16px;
  padding-bottom: 30px;
}

/* ===== 概览卡片 ===== */
.summary-card {
  background: linear-gradient(135deg, #0f3460, #16213e);
  border-radius: 14px;
  padding: 20px 12px;
  margin-bottom: 16px;
}
.summary-grid {
  display: flex;
}
.summary-cell {
  flex: 1;
  text-align: center;
}
.s-val {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: #fff;
}
.s-lbl {
  display: block;
  font-size: 11px;
  color: rgba(255,255,255,0.55);
  margin-top: 4px;
}

/* ===== 列表头部 ===== */
.list-head {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 12px;
}
.list-title {
  font-size: 17px;
  font-weight: 700;
  flex: 1;
}
.list-count {
  font-size: 12px;
  color: #bbb;
}
.btn-add {
  padding: 5px 14px;
  font-size: 13px;
  border-radius: 16px;
  background: linear-gradient(135deg, #0f3460, #16213e);
  color: #fff;
  border: none;
  line-height: 1.5;
  height: auto;
}

/* ===== 记录卡片 ===== */
.record-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 10px;
  padding: 14px 16px;
  margin-bottom: 8px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}
.rec-left {
  display: flex;
  flex-direction: column;
}
.rec-date {
  font-size: 14px;
  font-weight: 500;
}
.rec-bf {
  font-size: 11px;
  color: #999;
  margin-top: 2px;
}
.rec-right {
  display: flex;
  align-items: center;
  gap: 12px;
}
.rec-weight {
  font-size: 18px;
  font-weight: 700;
  color: #0f3460;
}
.rec-edit {
  font-size: 12px;
  color: #0f3460;
  padding: 2px 4px;
}
.rec-del {
  font-size: 12px;
  color: #ccc;
}

/* ===== 列表底部 ===== */
.list-end {
  text-align: center;
  padding: 16px 0 8px;
}
.list-end-text {
  font-size: 12px;
  color: #ddd;
}

/* ===== 弹窗 ===== */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.dialog {
  background: #fff;
  border-radius: 20px 20px 0 0;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
}
.dialog-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 20px 0;
}
.dialog-title {
  font-size: 18px;
  font-weight: 700;
}
.dialog-close {
  font-size: 20px;
  color: #ccc;
  padding: 4px;
}
.dialog-body {
  padding: 16px 20px 0;
}
.dialog-footer {
  display: flex;
  padding: 16px 20px 30px;
  gap: 10px;
}

/* 弹窗表单 */
.form-item {
  margin-bottom: 14px;
}
.form-label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #555;
  margin-bottom: 6px;
}
.form-input {
  width: 100%;
  height: 42px;
  border: 1px solid #e8e8e8;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  background: #fafafa;
  box-sizing: border-box;
}
.form-input-lg {
  height: 48px;
  font-size: 18px;
  font-weight: 600;
}

/* 弹窗按钮 */
.btn-cancel {
  flex: 1;
  height: 44px;
  line-height: 44px;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 10px;
  font-size: 15px;
  text-align: center;
}
.btn-confirm {
  flex: 1;
  height: 44px;
  line-height: 44px;
  background: linear-gradient(135deg, #0f3460, #16213e);
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 15px;
  text-align: center;
}
