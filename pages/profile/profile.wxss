.page { padding-bottom: 30px; }
.profile-header { position: relative; padding: 0 16px 20px; color: #fff; }
.profile-bg { position: absolute; top: 0; left: 0; right: 0; height: 280px; background: linear-gradient(160deg, #0f3460, #16213e); border-radius: 0 0 30px 30px; }
.profile-info { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; padding-top: 30px; }
.avatar { width: 80px; height: 80px; border-radius: 40px; border: 3px solid rgba(255,255,255,0.4); }
.nickname { font-size: 20px; font-weight: 600; margin-top: 12px; }
.uid { font-size: 13px; opacity: 0.6; margin-top: 4px; }
.profile-stats { position: relative; z-index: 1; display: flex; margin-top: 20px; background: rgba(255,255,255,0.1); border-radius: 12px; padding: 12px 0; }
.stat { flex: 1; text-align: center; }
.stat-num { display: block; font-size: 18px; font-weight: 700; }
.stat-label { font-size: 11px; opacity: 0.7; }
.menu-group { margin: 12px 16px; }
.menu-title { font-size: 13px; color: #999; padding: 0 4px 8px; }
.menu-item { display: flex; align-items: center; background: #fff; padding: 14px 16px; border-radius: 12px; margin-bottom: 2px; box-shadow: 0 1px 4px rgba(0,0,0,0.04); }
.menu-icon { font-size: 20px; margin-right: 12px; }
.menu-text { flex: 1; font-size: 15px; }
.menu-arrow { font-size: 18px; color: #ccc; }
.logout-text { color: #ff3b30; }
