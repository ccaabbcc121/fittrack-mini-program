<!-- pages/profile/profile.wxml -->
<view class="page">
  <view class="profile-header">
    <view class="profile-bg"></view>
    <view class="profile-info">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar-default.png'}}" mode="aspectFill"></image>
      <text class="nickname">{{userInfo.nickname || '未设置'}}</text>
      <text class="uid">ID: {{userInfo.id || '--'}}</text>
    </view>
    <view class="profile-stats">
      <view class="stat">
        <text class="stat-num">{{stats.weeklyWorkouts || 0}}</text>
        <text class="stat-label">本周训练</text>
      </view>
      <view class="stat">
        <text class="stat-num">{{stats.monthlyWorkouts || 0}}</text>
        <text class="stat-label">本月训练</text>
      </view>
      <view class="stat">
        <text class="stat-num">{{bmi}}</text>
        <text class="stat-label">BMI指数</text>
      </view>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-title">身体数据</view>
    <view class="menu-item" bindtap="goToBMI">
      <text class="menu-icon">📊</text>
      <text class="menu-text">BMI 计算器</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToWeight">
      <text class="menu-icon">⚖️</text>
      <text class="menu-text">体重管理</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-title">训练</view>
    <view class="menu-item" bindtap="goToPlans">
      <text class="menu-icon">📋</text>
      <text class="menu-text">训练计划</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToHistory">
      <text class="menu-icon">📝</text>
      <text class="menu-text">训练历史</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-title">饮食</view>
    <view class="menu-item" bindtap="goToDiet">
      <text class="menu-icon">🥗</text>
      <text class="menu-text">饮食记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToDietStats">
      <text class="menu-icon">📈</text>
      <text class="menu-text">热量统计</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-group">
    <view class="menu-item" bindtap="handleLogout">
      <text class="menu-icon">🚪</text>
      <text class="menu-text logout-text">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
