/* pages/training/list/list.wxss */
.page {
  padding: 16px;
  padding-bottom: 30px;
}

/* ===== 顶部操作栏 ===== */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.top-bar-left {
  display: flex;
  align-items: baseline;
  gap: 8px;
}
.top-title {
  font-size: 20px;
  font-weight: 700;
}
.top-count {
  font-size: 13px;
  color: #999;
}
.top-bar-right {
  display: flex;
  align-items: center;
  gap: 12px;
}
.top-link {
  font-size: 13px;
  color: #0f3460;
}
.btn-sm {
  padding: 6px 14px;
  font-size: 13px;
  border-radius: 16px;
  height: auto;
  line-height: 1.5;
}

/* ===== 加载 ===== */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 60px 0;
}
.loading-text {
  font-size: 14px;
  color: #999;
}

/* ===== 计划卡片 ===== */
.plan-card {
  margin-bottom: 12px;
  padding: 16px;
  position: relative;
}
.plan-card.plan-local {
  border: 1px dashed #e0e0e0;
  background: #fafafa;
}
.plan-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.plan-head-left {
  display: flex;
  align-items: center;
  gap: 8px;
}
.plan-type-tag {
  font-size: 11px;
  padding: 2px 10px;
  border-radius: 10px;
  font-weight: 500;
}
.plan-local-tag {
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 6px;
  background: #fff3cd;
  color: #856404;
}
.plan-head-right {
  display: flex;
  gap: 14px;
}
.plan-action {
  font-size: 13px;
  color: #0f3460;
}
.plan-action-del {
  color: #ccc;
}
.plan-name {
  font-size: 17px;
  font-weight: 600;
  display: block;
  margin-bottom: 4px;
}
.plan-desc {
  font-size: 13px;
  color: #888;
  display: block;
  margin-bottom: 10px;
  line-height: 1.5;
}
.plan-meta {
  display: flex;
  gap: 18px;
  margin-bottom: 8px;
}
.plan-meta-item {
  font-size: 13px;
  color: #666;
}
.meta-icon {
  font-size: 13px;
}

/* 训练动作 */
.plan-exercises {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}
.exercise-tag {
  font-size: 12px;
  background: #f5f5f5;
  color: #555;
  padding: 3px 10px;
  border-radius: 4px;
}

/* 打卡区域 */
.plan-checkin {
  margin-top: 4px;
}
.btn-checkin {
  width: 100%;
  height: 38px;
  line-height: 38px;
  background: linear-gradient(135deg, #0f3460, #16213e);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
}
.checked-in-badge {
  text-align: center;
  padding: 10px;
  background: #f0faf0;
  border-radius: 8px;
  font-size: 13px;
  color: #34c759;
}

/* ===== 底部 ===== */
.list-footer {
  text-align: center;
  padding: 20px 0 10px;
}
.footer-text {
  font-size: 12px;
  color: #ddd;
}
