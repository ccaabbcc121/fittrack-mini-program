.page { padding: 16px; }
.bmi-card { margin-bottom: 16px; }
.card-title { font-size: 18px; font-weight: 600; display: block; }
.card-desc { font-size: 13px; color: #999; margin-top: 6px; display: block; margin-bottom: 20px; }
.bmi-result { display: flex; flex-direction: column; align-items: center; margin-top: 24px; }
.bmi-circle { width: 120px; height: 120px; border-radius: 60px; border: 4px solid; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.bmi-value { font-size: 36px; font-weight: 700; }
.bmi-label { font-size: 12px; color: #999; }
.bmi-category { font-size: 18px; font-weight: 600; margin-top: 12px; }
.bmi-advice { background: #f8f9fa; border-radius: 8px; padding: 12px 16px; margin-top: 12px; width: 100%; text-align: center; box-sizing: border-box; }
.advice-text { font-size: 13px; color: #666; line-height: 1.5; }
.bmi-ref { margin-top: 16px; }
.ref-list { margin-top: 12px; }
.ref-item { display: flex; align-items: center; padding: 8px 0; }
.ref-dot { width: 10px; height: 10px; border-radius: 5px; margin-right: 10px; }
.ref-range { width: 90px; font-weight: 500; font-size: 14px; }
.ref-label { font-size: 13px; color: #999; }
